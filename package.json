{
  "name": "alphaloop",
  "version": "0.1.0",
  "description": "Turn any embeddings dataset into an agentic retrieval loop with query expansion, LLM re-ranking, and iterative refinement",
  "type": "module",
  "license": "MIT",
  "author": "Ryan Prendergast",
  "repository": {
    "type": "git",
    "url": "https://github.com/rprend/alphaloop.git"
  },
  "homepage": "https://github.com/rprend/alphaloop#readme",
  "keywords": [
    "embeddings",
    "rag",
    "retrieval",
    "search",
    "agentic",
    "llm",
    "re-ranking",
    "query-expansion",
    "ai-sdk",
    "cloudflare-workers"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./handler": {
      "import": "./dist/handler.js",
      "types": "./dist/handler.d.ts"
    },
    "./react": {
      "import": "./dist/react/index.js",
      "types": "./dist/react/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "demo": "vite --config demo/vite.config.js",
    "demo:build": "vite build --config demo/vite.config.js",
    "demo:stress": "npm run build && node demo/scripts/run-recursion-stress.mjs",
    "demo:dataset": "node demo/scripts/generate-real-dataset.mjs",
    "demo:real-stress": "npm run build && node demo/scripts/run-real-recursion-stress.mjs"
  },
  "peerDependencies": {
    "@assistant-ui/react": "^0.12.0",
    "@assistant-ui/react-ai-sdk": "^1.3.0",
    "ai": "^6.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "zod": "^3.23.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "@assistant-ui/react": {
      "optional": true
    },
    "@assistant-ui/react-ai-sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "@assistant-ui/react": "^0.12.0",
    "@assistant-ui/react-ai-sdk": "^1.3.0",
    "@types/react": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "ai": "^6.0.0",
    "react": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.3",
    "zod": "^3.23.0"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.48"
  }
}
